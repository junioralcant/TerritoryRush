# Database (Supabase Postgres in production; local Docker stack for development)
DATABASE_URL=postgres://territory:territory@localhost:5433/territory_rush

# Supabase Auth JWT secret used to verify tokens issued to the mobile app.
# Get it from Supabase dashboard: Settings > API > JWT Secret.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters

# Accepted JWT audience (Supabase issues "authenticated" for logged-in users).
SUPABASE_JWT_AUD=authenticated

PORT=3000
