# Territory Rush — mobile (Expo) env template. Copie para .env e preencha.
# Todas as vars precisam do prefixo EXPO_PUBLIC_ para chegar ao app (src/config.ts).

# API backend (no simulador iOS, localhost = host).
EXPO_PUBLIC_API_URL=http://localhost:3000

# Supabase Auth — Settings > API do projeto.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Strava OAuth app — https://www.strava.com/settings/api
EXPO_PUBLIC_STRAVA_CLIENT_ID=

# Feature flag Garmin (default off).
EXPO_PUBLIC_GARMIN_ENABLED=false
