{
  "name": "territory-rush",
  "version": "0.1.0",
  "private": true,
  "description": "Territory Rush — gamified running territory game (MVP).",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "api:dev": "npm run start:dev --workspace apps/api",
    "api:test": "npm run test --workspace apps/api",
    "api:test:int": "npm run test:int --workspace apps/api",
    "api:lint": "npm run lint --workspace apps/api",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "engines": {
    "node": ">=20"
  }
}
